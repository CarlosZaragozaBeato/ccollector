# =============================================================================
# CCollector — environment variable reference
# Copy to .env.local (never commit that file) and fill in the values marked
# REQUIRED. Values marked OPTIONAL already have a working default.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME
# For docker compose: DB_JDBC_URL is set automatically in docker-compose.yml
# from the 'db' service hostname. You only need to set this for a manual /
# external database setup.
# Example: jdbc:postgresql://localhost:5432/zensyra?currentSchema=collector
DB_JDBC_URL=CHANGE_ME

# -----------------------------------------------------------------------------
# Docker Compose (OPTIONAL — used by docker-compose.yml only)
# -----------------------------------------------------------------------------
# Name of the PostgreSQL database created inside the db container.
# The application schema 'collector' is always created inside this database.
POSTGRES_DB=collector

# -----------------------------------------------------------------------------
# Encryption (REQUIRED)
# AES-256-GCM key for stored OAuth tokens and client secrets.
# Must be exactly 32 bytes, base64-encoded.
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
COLLECTOR_ENCRYPTION_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# Security (REQUIRED)
# -----------------------------------------------------------------------------
# Bearer token for read API routes under /api/v1  (X-API-Key header)
COLLECTOR_API_KEY=CHANGE_ME
# Bearer token for admin/trigger routes under /admin  (X-Admin-Token header)
ADMIN_TOKEN=CHANGE_ME

# -----------------------------------------------------------------------------
# HTTP (OPTIONAL — defaults shown)
# -----------------------------------------------------------------------------
HTTP_PORT=8080

# -----------------------------------------------------------------------------
# Logging (OPTIONAL — defaults shown)
# -----------------------------------------------------------------------------
QUARKUS_LOG_LEVEL=INFO
ZENSYRA_LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# Quartz scheduler (OPTIONAL)
# For local development use ram + false; for production use jdbc-cmt + true.
# -----------------------------------------------------------------------------
QUARTZ_STORE_TYPE=ram
QUARTZ_CLUSTERED=false

# -----------------------------------------------------------------------------
# Strava — stream sync tuning (OPTIONAL — defaults shown)
# -----------------------------------------------------------------------------
STRAVA_STREAMS_BATCH_SIZE=10
STRAVA_STREAMS_RETRY_LIMIT=3

# -----------------------------------------------------------------------------
# Strava API credentials
# The application loads these from the database (integration_credentials table),
# NOT from the process environment. These entries exist here solely as a handoff
# mechanism: scripts/bootstrap-env.sh writes them so that
# scripts/seed-strava-credentials.sh (#49) can source this file and call
# POST /admin/credentials/strava to insert them via JPA encryption.
# Get them from: https://www.strava.com/settings/api
# See README.md: "Step 1 — Create a Strava API application"
# -----------------------------------------------------------------------------
STRAVA_CLIENT_ID=CHANGE_ME
STRAVA_CLIENT_SECRET=CHANGE_ME
