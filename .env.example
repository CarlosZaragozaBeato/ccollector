# =============================================================================
# CCollector — environment variable reference
# Copy to .env.local (never commit that file) and fill in the values marked
# REQUIRED. Values marked OPTIONAL already have a working default.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME
# Example: jdbc:postgresql://localhost:5432/zensyra?currentSchema=collector
DB_JDBC_URL=CHANGE_ME

# -----------------------------------------------------------------------------
# Encryption (REQUIRED)
# AES-256-GCM key for stored OAuth tokens and client secrets.
# Must be exactly 32 bytes, base64-encoded.
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
COLLECTOR_ENCRYPTION_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# Security (REQUIRED)
# -----------------------------------------------------------------------------
# Bearer token for read API routes under /api/v1  (X-API-Key header)
COLLECTOR_API_KEY=CHANGE_ME
# Bearer token for admin/trigger routes under /admin  (X-Admin-Token header)
ADMIN_TOKEN=CHANGE_ME

# -----------------------------------------------------------------------------
# HTTP (OPTIONAL — defaults shown)
# -----------------------------------------------------------------------------
HTTP_PORT=8080

# -----------------------------------------------------------------------------
# Logging (OPTIONAL — defaults shown)
# -----------------------------------------------------------------------------
QUARKUS_LOG_LEVEL=INFO
ZENSYRA_LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# Quartz scheduler (OPTIONAL)
# For local development use ram + false; for production use jdbc-cmt + true.
# -----------------------------------------------------------------------------
QUARTZ_STORE_TYPE=ram
QUARTZ_CLUSTERED=false

# -----------------------------------------------------------------------------
# Strava — stream sync tuning (OPTIONAL — defaults shown)
# -----------------------------------------------------------------------------
STRAVA_STREAMS_BATCH_SIZE=10
STRAVA_STREAMS_RETRY_LIMIT=3

# -----------------------------------------------------------------------------
# Strava API credentials — NOT env vars, loaded from the database.
# These are shown here for reference only. After starting the app, insert
# them into the integration_credentials table with the SQL in the README.
#
#   STRAVA_CLIENT_ID=<your numeric client id>
#   STRAVA_CLIENT_SECRET=<your client secret>
# -----------------------------------------------------------------------------
